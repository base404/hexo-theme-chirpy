<div class="about-wrapper">
  <h1 class="page-title"><i class="fa-solid fa-user"></i> 关于</h1>

  <div class="about-container">
    <% const about = theme.about || {}; %>

    <div class="about-hero-card">
      <div class="about-avatar-wrapper">
        <img src="<%= url_for(about.avatar || theme.avatar || '/images/avatar.png') %>" alt="<%= about.name || theme.author || config.author %>" class="about-avatar" />
      </div>
      <div class="about-hero-info">
        <h2 class="about-name"><%= about.name || theme.author || config.author %></h2>
        <p class="about-title-role"><%= about.role || 'Full Stack Developer / Open Source Enthusiast' %></p>
        <p class="about-bio"><i class="fa-solid fa-quote-left"></i> <%= about.bio || theme.subtitle || config.subtitle %> <i class="fa-solid fa-quote-right"></i></p>

        <% if (about.skills && about.skills.length > 0) { %>
          <div class="about-skills">
            <% about.skills.forEach(function(skill){ %>
              <span class="skill-pill"><%= skill %></span>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <% if (page.content) { %>
      <div class="about-content markdown-body">
        <%- page.content %>
      </div>
    <% } else if (about.description) { %>
      <div class="about-content markdown-body">
        <%- markdown(about.description) %>
      </div>
    <% } %>

    <%- partial('_partial/comments') %>
  </div>
</div>
