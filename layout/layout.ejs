<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>" data-preset="<%= theme.style_preset || 'chirpy' %>" data-scheme="<%= theme.color_scheme || 'auto' %>">
<head>
  <%- partial('_partial/head') %>
  <% if (theme.accent_color) { %>
    <style>:root { --color-accent: <%= theme.accent_color %>; }</style>
  <% } %>
</head>
<body class="chirpy-body preset-<%= theme.style_preset || 'chirpy' %>">
  <% if (theme.reading_progress !== false) { %>
    <div id="reading-progress" class="reading-progress"></div>
  <% } %>

  <!-- Mobile Top Navbar -->
  <nav class="mobile-topbar" id="mobile-topbar">
    <button class="mobile-menu-btn btn-icon" id="sidebar-toggle" aria-label="打开菜单">
      <i class="fa-solid fa-bars"></i>
    </button>
    <a href="<%= url_for('/') %>" class="mobile-site-title"><%= config.title %></a>
    <div class="mobile-topbar-right">
      <button id="mode-toggle-mobile" class="btn-icon" title="切换暗黑/浅色模式">
        <i class="fa-solid fa-adjust"></i>
      </button>
    </div>
  </nav>

  <!-- Sidebar Overlay (Mobile) -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <div class="app-layout">
    <!-- 1st Column: Left Sidebar Nav -->
    <%- partial('_partial/sidebar') %>

    <!-- 2nd Column: Main Content -->
    <main class="main-content">
      <div class="content-container">
        <%- body %>
      </div>

      <%- partial('_partial/footer') %>
    </main>

    <!-- 3rd Column: Right Sidebar (Home/List pages) or TOC (Article pages) -->
    <% if (is_post()) { %>
      <% if (theme.toc_enabled !== false) { %>
        <aside class="right-panel">
          <%- partial('_partial/toc') %>
        </aside>
      <% } %>
    <% } else { %>
      <%- partial('_partial/right_sidebar') %>
    <% } %>
  </div>

  <script src="<%= url_for('/js/main.js') %>"></script>
</body>
</html>
