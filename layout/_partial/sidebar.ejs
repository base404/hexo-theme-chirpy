<aside id="sidebar" class="chirpy-sidebar">
  <div class="sidebar-wrapper">
    <div class="profile-area">
      <a href="<%= url_for('/') %>" class="avatar-link">
        <img src="<%= url_for(theme.avatar || '/images/avatar.png') %>" alt="<%= theme.author || config.author %>" class="avatar-img">
      </a>
      <h1 class="site-title">
        <a href="<%= url_for('/') %>"><%= config.title %></a>
      </h1>
      <p class="site-subtitle"><%= theme.subtitle || config.subtitle %></p>
    </div>

    <nav class="sidebar-nav">
      <ul>
        <li class="nav-item <%= is_home() ? 'active' : '' %>">
          <a href="<%= url_for('/') %>">
            <i class="fa-solid fa-house fa-fw"></i>
            <span>首页</span>
          </a>
        </li>
        <li class="nav-item <%= page.type === 'categories' || is_category() ? 'active' : '' %>">
          <a href="<%= url_for('/categories') %>">
            <i class="fa-solid fa-bars-staggered fa-fw"></i>
            <span>分类</span>
          </a>
        </li>
        <li class="nav-item <%= page.type === 'tags' || is_tag() ? 'active' : '' %>">
          <a href="<%= url_for('/tags') %>">
            <i class="fa-solid fa-tags fa-fw"></i>
            <span>标签</span>
          </a>
        </li>
        <li class="nav-item <%= page.type === 'archive' || is_archive() ? 'active' : '' %>">
          <a href="<%= url_for('/archives') %>">
            <i class="fa-solid fa-box-archive fa-fw"></i>
            <span>归档</span>
          </a>
        </li>
        <li class="nav-item <%= page.type === 'links' || is_current('/links') ? 'active' : '' %>">
          <a href="<%= url_for('/links') %>">
            <i class="fa-solid fa-link fa-fw"></i>
            <span>友链</span>
          </a>
        </li>
        <li class="nav-item <%= page.type === 'about' || is_current('/about') ? 'active' : '' %>">
          <a href="<%= url_for('/about') %>">
            <i class="fa-solid fa-user fa-fw"></i>
            <span>关于</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="sidebar-bottom">
      <button id="mode-toggle" class="btn-icon" title="切换暗黑/浅色模式">
        <i class="fa-solid fa-adjust"></i>
      </button>

      <div class="social-links">
        <% const social = theme.social || {}; %>
        <% if (social.github) { %>
          <a href="<%= social.github %>" target="_blank" rel="noreferrer" title="GitHub">
            <i class="fa-brands fa-github"></i>
          </a>
        <% } %>

        <% if (social.rss) { %>
          <a href="<%= url_for(social.rss) %>" target="_blank" title="RSS Feed">
            <i class="fa-solid fa-rss"></i>
          </a>
        <% } %>

        <% if (social.email) { %>
          <a href="<%= social.email.startsWith('mailto:') ? social.email : 'mailto:' + social.email %>" target="_blank" title="电子邮箱">
            <i class="fa-solid fa-envelope"></i>
          </a>
        <% } %>

        <% if (social.qq) { %>
          <a href="<%= social.qq.startsWith('http') || social.qq.startsWith('tencent') ? social.qq : 'tencent://message/?uin=' + social.qq %>" target="_blank" title="QQ">
            <i class="fa-brands fa-qq"></i>
          </a>
        <% } %>

        <% if (social.wechat || social.wx) { %>
          <% const wxVal = social.wechat || social.wx; %>
          <a href="<%= url_for(wxVal) %>" target="_blank" title="微信 WeChat">
            <i class="fa-brands fa-weixin"></i>
          </a>
        <% } %>
      </div>
    </div>
  </div>
</aside>
